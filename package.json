{
  "name": "portfolio",
  "version": "1.0.0",
  "description": "Christopher Cadger \u2014 AI Engineer Portfolio",
  "main": "electron/main.js",
  "author": "Christopher Cadger <cadger808@codeberg.org>",
  "license": "UNLICENSED",
  "scripts": {
    "electron": "electron .",
    "electron:dev": "NODE_ENV=development electron .",
    "electron:build": "electron-builder --linux",
    "electron:dist": "electron-builder --linux AppImage rpm"
  },
  "dependencies": {
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.cadger808.portfolio",
    "productName": "Christopher Cadger Portfolio",
    "copyright": "Copyright \u00a9 2025 Christopher Cadger",
    "directories": {
      "output": "dist-electron",
      "buildResources": "icons"
    },
    "files": [
      "index.html",
      "api-client.js",
      "resume.html",
      "Christopher-Cadger-Resume.pdf",
      "manifest.json",
      "sw.js",
      "avatar-widget.js",
      "share-widget.js",
      "icons/**",
      "electron/**",
      "!node_modules/**",
      "!dist-electron/**"
    ],
    "linux": {
      "target": [
        "AppImage",
        "rpm"
      ],
      "category": "Utility",
      "icon": "icons/icon-512.png",
      "desktop": {
        "Name": "Christopher Cadger Portfolio",
        "Comment": "AI Engineer Portfolio",
        "Categories": "Utility;Development"
      }
    },
    "publish": {
      "provider": "generic",
      "url": "https://codeberg.org/cadger808/portfolio/releases/download/latest/"
    }
  },
  "overrides": {
    "picomatch": ">=4.0.2",
    "brace-expansion": ">=2.0.1"
  }
}